{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-playbox",
  "name": {
    "ko": "\ud50c\ub808\uc774\ubc15\uc2a4",
    "en": "Playbox"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\ube44\ub514\uc624 \ub77c\uc774\ube0c\ub7ec\ub9ac\u00b7\ud50c\ub808\uc774\uc5b4 \u2014 \uc990\uaca8\ucc3e\uae30\u00b7\ud074\ub9bd. YouTube\u00b7\ub85c\uceec \ud30c\uc77c\u00b7\uc9c1\uc811 \ubbf8\ub514\uc5b4 URL\u00b7\uc784\uc758 \uc6f9\ud398\uc774\uc9c0(yt-dlp \uacbd\uc720)\ub97c \uc7ac\uc0dd\ud558\uace0, \ubcf4\ud638\ub41c HLS \ub294 \ucf54\uc5b4 \ubbf8\ub514\uc5b4 \ud504\ub85d\uc2dc\ub85c \uc2a4\ud2b8\ub9ac\ubc0d.",
    "en": "Video library and player \u2014 favorites and clips. Plays YouTube, local files, direct media URLs, and arbitrary web pages (via yt-dlp); protected HLS is streamed through the core media proxy."
  },
  "entry": "main.js",
  "consumes": [
    {
      "id": "soksak-spec-plugin-browser",
      "range": "0.0.1"
    }
  ],
  "configuration": [
    {
      "key": "domainMap",
      "type": "map",
      "default": [],
      "title": {
        "ko": "\ub3c4\uba54\uc778 \ub9e4\ud551",
        "en": "Domain mapping"
      },
      "description": {
        "ko": "\uc6d0\ubcf8 \ud638\uc2a4\ud2b8 \u2192 \ubbf8\ub7ec \ud638\uc2a4\ud2b8. \uc811\uc18d \ucc28\ub2e8 \ud638\uc2a4\ud2b8\ub97c \uc811\uc18d \uac00\ub2a5\ud55c \ubbf8\ub7ec \ud638\uc2a4\ud2b8\ub85c \uce58\ud658\ud569\ub2c8\ub2e4. + \ucd94\uac00\ub85c \uc5ec\ub7ec \uac1c, \u2715 \ub85c \uc0ad\uc81c.",
        "en": "Original host \u2192 mirror host. Replace a blocked host with a reachable mirror. Use + to add, \u2715 to remove."
      }
    },
    {
      "key": "extractMode",
      "type": "enum",
      "default": "hidden",
      "enum": [
        "hidden",
        "tab"
      ],
      "enumLabels": [
        {
          "ko": "\uc228\uae40(\uc624\ud504\uc2a4\ud06c\ub9b0)",
          "en": "Hidden (offscreen)"
        },
        {
          "ko": "\ud0ed(\ubcf4\uc784)",
          "en": "Tab (visible)"
        }
      ],
      "title": {
        "ko": "\ucd94\ucd9c \ubc29\uc2dd",
        "en": "Extract mode"
      },
      "description": {
        "ko": "\uc6f9\ud398\uc774\uc9c0\uc5d0\uc11c \uc2a4\ud2b8\ub9bc\uc744 \ucd94\ucd9c\ud558\ub294 \ubc29\uc2dd. \uc228\uae40=\ubcf4\uc774\uc9c0 \uc54a\uac8c \uc624\ud504\uc2a4\ud06c\ub9b0\uc5d0\uc11c. \ud0ed=\ube0c\ub77c\uc6b0\uc800 \ud0ed\uc744 \ub744\uc6cc \uc9c1\uc811 \uc7ac\uc0dd\uc744 \ub204\ub97c \uc218 \uc788\uc74c(\ud398\uc774\uc9c0\uac00 \ud074\ub9ad\uc744 \uc694\uad6c\ud560 \ub54c).",
        "en": "How to extract a stream from a web page. Hidden = offscreen, invisible. Tab = open a visible browser tab so you can click play (for pages that require interaction)."
      }
    },
    {
      "key": "sniffTimeoutMs",
      "type": "number",
      "default": 15000,
      "min": 3000,
      "max": 60000,
      "title": {
        "ko": "\ucd94\ucd9c \ub300\uae30(ms)",
        "en": "Extract wait (ms)"
      },
      "description": {
        "ko": "\uc6f9\ud398\uc774\uc9c0\uc5d0\uc11c \ubbf8\ub514\uc5b4 \uc2a4\ud2b8\ub9bc\uc744 \ucd94\ucd9c\ud560 \ub54c \ucd5c\ub300 \ub300\uae30 \uc2dc\uac04.",
        "en": "Maximum wait when extracting a media stream from a web page."
      }
    },
    {
      "key": "downloadDir",
      "type": "string",
      "default": "",
      "title": {
        "ko": "\ub2e4\uc6b4\ub85c\ub4dc \ud3f4\ub354",
        "en": "Download folder"
      },
      "description": {
        "ko": "\ub2e4\uc6b4\ub85c\ub4dc\ub97c \uc800\uc7a5\ud560 \ud3f4\ub354(\uc808\ub300\uacbd\ub85c). \ube44\uc5b4 \uc788\uc73c\uba74 \ub2e4\uc6b4\ub85c\ub4dc \ubc84\ud2bc\uc774 \ud3f4\ub354 \uc9c0\uc815\uc744 \uc694\uccad\ud569\ub2c8\ub2e4.",
        "en": "Absolute folder where downloads are saved. If empty, the download button asks you to set it first."
      }
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "commands:inject",
    "data",
    "process",
    "programs",
    "fs:read"
  ],
  "contributes": {
    "views": [
      {
        "id": "library",
        "title": {
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac",
          "en": "Library"
        },
        "icon": "\u25b6",
        "placements": [
          "sidebar-right"
        ],
        "defaultPlacement": "sidebar-right"
      },
      {
        "id": "player",
        "title": {
          "ko": "\ud50c\ub808\uc774\uc5b4",
          "en": "Player"
        },
        "icon": "\u25b7",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "busy"
        ]
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "\uc801\uc7ac/\ubc84\uc804 \ud655\uc778",
          "en": "Ping"
        }
      },
      {
        "name": "favorite.add",
        "title": {
          "ko": "\uc990\uaca8\ucc3e\uae30 \ucd94\uac00",
          "en": "Add favorite"
        }
      },
      {
        "name": "favorite.remove",
        "title": {
          "ko": "\ud56d\ubaa9 \uc0ad\uc81c",
          "en": "Remove item"
        },
        "danger": "destructive"
      },
      {
        "name": "library.list",
        "title": {
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \ubaa9\ub85d",
          "en": "List library"
        }
      },
      {
        "name": "library.filter",
        "title": {
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \ud544\ud130",
          "en": "Filter library"
        }
      },
      {
        "name": "resolve",
        "title": {
          "ko": "URL \ud574\uc11d",
          "en": "Resolve URL"
        }
      },
      {
        "name": "play",
        "title": {
          "ko": "\uc7ac\uc0dd",
          "en": "Play"
        },
        "danger": "inject"
      },
      {
        "name": "clip.add",
        "title": {
          "ko": "\ud074\ub9bd \ucd94\uac00",
          "en": "Add clip"
        }
      },
      {
        "name": "clip.list",
        "title": {
          "ko": "\ud074\ub9bd \ubaa9\ub85d",
          "en": "List clips"
        }
      },
      {
        "name": "clip.update",
        "title": {
          "ko": "\ud074\ub9bd \uc218\uc815",
          "en": "Update clip"
        }
      },
      {
        "name": "player.state",
        "title": {
          "ko": "\uc7ac\uc0dd \uc0c1\ud0dc",
          "en": "Player state"
        }
      },
      {
        "name": "player.control",
        "title": {
          "ko": "\uc7ac\uc0dd \uc81c\uc5b4",
          "en": "Player control"
        },
        "danger": "inject"
      },
      {
        "name": "download",
        "title": {
          "ko": "\ub2e4\uc6b4\ub85c\ub4dc",
          "en": "Download"
        },
        "danger": "inject"
      },
      {
        "name": "doctor",
        "title": {
          "ko": "\uc758\uc874\uc131 \uc810\uac80",
          "en": "Doctor"
        }
      },
      {
        "name": "setup",
        "title": {
          "ko": "\uc758\uc874\uc131 \uc124\uce58",
          "en": "Setup deps"
        },
        "danger": "inject"
      },
      {
        "name": "debug",
        "title": {
          "ko": "\uc778\uc2a4\ud134\uc2a4 \uc9c4\ub2e8",
          "en": "Debug instance"
        }
      }
    ],
    "programs": [
      {
        "id": "playbox",
        "title": {
          "ko": "\ud50c\ub808\uc774\ubc15\uc2a4",
          "en": "Playbox"
        },
        "path": {
          "ko": "\uc720\ud2f8\ub9ac\ud2f0",
          "en": "Utility"
        },
        "kind": "view",
        "view": "player"
      }
    ],
    "nodes": [
      {
        "id": "url-input",
        "description": {
          "en": "Video URL input",
          "ko": "\ube44\ub514\uc624 URL \uc785\ub825"
        }
      },
      {
        "id": "play",
        "description": {
          "en": "Play the entered URL",
          "ko": "\uc785\ub825 URL \uc7ac\uc0dd"
        }
      },
      {
        "id": "open-file",
        "description": {
          "en": "Open file picker",
          "ko": "\ud30c\uc77c \uc120\ud0dd \uc5f4\uae30"
        }
      },
      {
        "id": "dropzone",
        "description": {
          "en": "Drag-drop target for video files",
          "ko": "\ub3d9\uc601\uc0c1 \ud30c\uc77c \ub4dc\ub86d \uc601\uc5ed"
        }
      },
      {
        "id": "video",
        "description": {
          "en": "The video element",
          "ko": "\ube44\ub514\uc624 \uc694\uc18c"
        }
      },
      {
        "id": "playstate",
        "description": {
          "en": "Live playback state (currentTime centisec/paused/readyState)",
          "ko": "\uc2e4\uc7ac\uc0dd \uc0c1\ud0dc(currentTime \uc13c\ud2f0\ucd08/\uc77c\uc2dc\uc815\uc9c0/readyState)"
        }
      },
      {
        "id": "clipstate",
        "description": {
          "en": "Clip segment/loop state (start centisec/end centisec/loop)",
          "ko": "\ud074\ub9bd \uad6c\uac04/\ubc18\ubcf5 \uc0c1\ud0dc(\uc2dc\uc791 \uc13c\ud2f0\ucd08/\ub05d \uc13c\ud2f0\ucd08/\ubc18\ubcf5)"
        }
      },
      {
        "id": "loop",
        "description": {
          "en": "Toggle clip segment repeat",
          "ko": "\ud074\ub9bd \uad6c\uac04 \ubc18\ubcf5 \ud1a0\uae00"
        }
      },
      {
        "id": "frame",
        "description": {
          "en": "The embedded player iframe",
          "ko": "\uc784\ubca0\ub4dc \ud50c\ub808\uc774\uc5b4"
        }
      },
      {
        "id": "clip-start",
        "description": {
          "en": "Mark clip start",
          "ko": "\ud074\ub9bd \uc2dc\uc791 \ud45c\uc2dc"
        }
      },
      {
        "id": "clip-end",
        "description": {
          "en": "Mark clip end and save",
          "ko": "\ud074\ub9bd \ub05d \ud45c\uc2dc\u00b7\uc800\uc7a5"
        }
      },
      {
        "id": "close",
        "description": {
          "en": "Close current media",
          "ko": "\ud604\uc7ac \ubbf8\ub514\uc5b4 \ub2eb\uae30"
        }
      },
      {
        "id": "download",
        "description": {
          "en": "Download current media (full or marked clip)",
          "ko": "\ud604\uc7ac \ubbf8\ub514\uc5b4 \uc800\uc7a5(\uc804\uccb4 \ub610\ub294 \ud45c\uc2dc \uad6c\uac04)"
        }
      },
      {
        "id": "flash",
        "description": {
          "en": "Transient status message",
          "ko": "\uc77c\uc2dc \uc0c1\ud0dc \uba54\uc2dc\uc9c0"
        }
      },
      {
        "id": "error",
        "description": {
          "en": "Resolve/playback error message",
          "ko": "\ud574\uc11d/\uc7ac\uc0dd \uc624\ub958 \uba54\uc2dc\uc9c0"
        }
      },
      {
        "id": "lib-input",
        "description": {
          "en": "Library add-URL input",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac URL \ucd94\uac00 \uc785\ub825"
        }
      },
      {
        "id": "lib-add",
        "description": {
          "en": "Add favorite button",
          "ko": "\uc990\uaca8\ucc3e\uae30 \ucd94\uac00 \ubc84\ud2bc"
        }
      },
      {
        "id": "lib-filter",
        "description": {
          "en": "Library filter input",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \ud544\ud130 \uc785\ub825"
        }
      },
      {
        "id": "lib-kind",
        "description": {
          "en": "Library kind filter (all/favorite/clip)",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \uc885\ub958 \ud544\ud130"
        }
      },
      {
        "id": "list",
        "description": {
          "en": "Library list container",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \ubaa9\ub85d"
        }
      },
      {
        "id": "item",
        "description": {
          "en": "Library row (item/<id>)",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \ud589"
        }
      },
      {
        "id": "edit",
        "description": {
          "en": "Edit clip start/end button (edit/<id>)",
          "ko": "\ud074\ub9bd \uc2dc\uc791/\uc885\ub8cc \uc218\uc815 \ubc84\ud2bc"
        }
      },
      {
        "id": "edit-panel",
        "description": {
          "en": "Inline clip edit panel (edit-panel/<id>)",
          "ko": "\ud074\ub9bd \uc778\ub77c\uc778 \ud3b8\uc9d1 \ud328\ub110"
        }
      },
      {
        "id": "clip-edit-start",
        "description": {
          "en": "Clip edit start input (sec.cs)",
          "ko": "\ud074\ub9bd \ud3b8\uc9d1 \uc2dc\uc791 \uc785\ub825(\ucd08.00)"
        }
      },
      {
        "id": "clip-edit-end",
        "description": {
          "en": "Clip edit end input (sec.cs)",
          "ko": "\ud074\ub9bd \ud3b8\uc9d1 \uc885\ub8cc \uc785\ub825(\ucd08.00)"
        }
      },
      {
        "id": "clip-edit-save",
        "description": {
          "en": "Save clip edit",
          "ko": "\ud074\ub9bd \ud3b8\uc9d1 \uc800\uc7a5"
        }
      },
      {
        "id": "clip-edit-cancel",
        "description": {
          "en": "Cancel clip edit",
          "ko": "\ud074\ub9bd \ud3b8\uc9d1 \ucde8\uc18c"
        }
      },
      {
        "id": "lib-flash",
        "description": {
          "en": "Library transient status message",
          "ko": "\ub77c\uc774\ube0c\ub7ec\ub9ac \uc0c1\ud0dc \uba54\uc2dc\uc9c0"
        }
      },
      {
        "id": "dlstate",
        "description": {
          "en": "Download result state (idle/busy/ok/fail)",
          "ko": "\ub2e4\uc6b4\ub85c\ub4dc \uacb0\uacfc \uc0c1\ud0dc"
        }
      },
      {
        "id": "remove",
        "description": {
          "en": "Remove row button (remove/<id>)",
          "ko": "\ud589 \uc0ad\uc81c \ubc84\ud2bc"
        }
      },
      {
        "id": "debug",
        "description": {
          "en": "Instance/scope diagnostic (instanceId|scope|count)",
          "ko": "\uc778\uc2a4\ud134\uc2a4/scope \uc9c4\ub2e8"
        }
      }
    ]
  }
}
