{
  "name": "soksak-plugin-playbox",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "soksak Playbox \u2014 video library + player (favorites, clips) with HLS/MP4/YouTube/local playback via the core media proxy and yt-dlp",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "tsc --noEmit && vitest run && node build.mjs",
    "doctor": "soksak-plugin-doctor",
    "prepublishOnly": "npm run doctor",
    "test-unit": "npm run typecheck && vitest run"
  },
  "dependencies": {
    "hls.js": "^1.5.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.24.2",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8",
    "soksak-plugin-doctor": "github:soksak-ai/soksak-plugin-doctor"
  },
  "soksakRelease": {
    "kind": "plugin",
    "id": "soksak-plugin-playbox",
    "repository": "https://github.com/soksak-ai/soksak-plugin-playbox",
    "manifest": "release.json"
  }
}
